HUGGING_FACE_HUB_TOKEN=huggingface_token_here
OCR_VLLM_IMAGE=vllm/vllm-openai:latest
OCR_GPU_ID=0
OCR_GPU_MEMORY_UTILIZATION=0.6
LOCAL_MODEL_DIR=./models
OCR_MODEL=/models/LightOnOCR-2-1B

# Neu muon tai model tu Hugging Face thi doi lai, vi du:
# OCR_MODEL=lightonai/LightOnOCR-2-1B

# OCR service settings
OCR_URL=http://ocr-service:8000/v1/chat/completions
OCR_TEMPERATURE=0.2
OCR_MAX_TOKENS=2048
OCR_TOP_P=0.9
CORS_ALLOW_ORIGINS=*
